{
  "base_url": "https://precice.org",
  "categories": {
    "about": {
      "description": "project overview, roadmap, adopters",
      "sources": [
        {
          "repo": "precice/precice.github.io",
          "checkout_path": "content/about",
          "docs_subdir": "content/about"
        }
      ],
      "exclude_patterns": []
    },
    "community": {
      "description": "community resources, publications, events",
      "sources": [
        {
          "repo": "precice/precice.github.io",
          "checkout_path": "content/community",
          "docs_subdir": "content/community"
        }
      ],
      "exclude_patterns": []
    },
    "documentation": {
      "description": "XML configuration reference, fundamentals, adapters, installation, tooling",
      "sources": [
        {
          "repo": "precice/precice.github.io",
          "checkout_path": "content/docs",
          "docs_subdir": "content/docs"
        },
        {
          "repo": "precice/precice",
          "checkout_path": "docs",
          "docs_subdir": "docs",
          "branch": "develop"
        }
      ],
      "exclude_patterns": [
        "docs/_index.md",
        "docs/docs-meta"
      ]
    },
    "tutorials": {
      "description": "step-by-step tutorial walkthroughs and tutorial case READMEs",
      "sources": [
        {
          "repo": "precice/precice.github.io",
          "checkout_path": "content/tutorials",
          "docs_subdir": "content/tutorials"
        },
        {
          "repo": "precice/tutorials",
          "checkout_path": "",
          "docs_subdir": "",
          "branch": "develop"
        }
      ],
      "exclude_patterns": [
        "tutorials/_index.md"
      ]
    },
    "forum": {
      "description": "recent precice.discourse.group topics",
      "type": "discourse",
      "forum_url": "https://precice.discourse.group"
    },
    "issues": {
      "description": "precice/precice GitHub issues (bug reports, questions, errors)",
      "type": "github_issues",
      "repo": "precice/precice"
    },
    "pulls": {
      "description": "precice/precice GitHub pull requests (fixes, features, discussion)",
      "type": "github_prs",
      "repo": "precice/precice"
    }
  }
